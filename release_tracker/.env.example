# Copy to .env and fill in real values. .env is gitignored.

# Postgres connection string used by SQLModel.
DATABASE_URL=postgresql+psycopg://release_tracker:release_tracker@localhost:5433/release_tracker

# AI provider: ollama (local, free) | gemini (cloud) | mock (offline demo)
AI_PROVIDER=ollama

# Ollama — install from https://ollama.com
# Run `ollama list` to see installed models, then set OLLAMA_MODEL to one of them.
# To install a model: ollama pull gemma3
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=gemma3:latest

# Gemini — only needed when AI_PROVIDER=gemini
# Get a key at https://aistudio.google.com/apikey
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.0-flash
